{% extends 'tenant/base.html' %}
{% block title %}Payment History | {{ tenant.name }}{% endblock %}

{% block body %}
<div class="page-header">
    <div>
        <h1 class="page-title">📜 Payment History</h1>
        <p class="page-desc">Complete record of all fee transactions</p>
    </div>
    <div class="header-stats">
        <div class="stat-badge">💰 Total Amount: <strong>₹{{ total_amount|floatformat:2 }}</strong></div>
        <div class="stat-badge">📋 Total Payments: <strong>{{ payments.paginator.count }}</strong></div>
    </div>
</div>

<!-- Search & Filters -->
<div class="filter-card">
    <form method="get" class="filter-form">
        <div class="filter-group">
            <input type="text" name="search" placeholder="Search by receipt, student name, roll, CNIC..." value="{{ search_query }}" class="filter-input">
        </div>
        <div class="filter-group">
            <select name="mode" class="filter-select">
                <option value="">All Modes</option>
                {% for code, name in mode_choices %}
                <option value="{{ code }}" {% if mode_filter == code %}selected{% endif %}>{{ name }}</option>
                {% endfor %}
            </select>
        </div>
        <div class="filter-actions">
            <button type="submit" class="btn-filter">🔍 Filter</button>
            <a href="{% url 'payment_history' %}" class="btn-reset">Reset</a>
        </div>
    </form>
</div>

<!-- Payments Table -->
<div class="table-card">
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Receipt No</th>
                    <th>Student Name</th>
                    <th>Roll No</th>
                    <th>Amount (₹)</th>
                    <th>Date</th>
                    <th>Mode</th>
                    <th>Type</th>
                    <th>Receipt</th>
                </tr>
            </thead>
            <tbody>
                {% for p in payments %}
                <tr>
                    <td><code>{{ p.receipt_number }}</code></td>
                    <td>{{ p.student.name }}<br><small class="text-muted">Father: {{ p.student.father_name }}</small></td>
                    <td>{{ p.student.roll_number }}</td>
                    <td class="amount">₹{{ p.amount|floatformat:2 }}</td>
                    <td>{{ p.payment_date|date:"d M Y" }}</td>
                    <td>{{ p.get_payment_mode_display }}</td>
                    <td>{{ p.get_payment_type_display }}</td>
                    <td><a href="{% url 'fee_receipt' schema_name=tenant.schema_name receipt_id=p.id %}" class="btn-sm" target="_blank">View</a></td>
                </tr>
                {% empty %}
                <tr>
                    <td colspan="8" class="empty-row">
                        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="10"/><path d="M8 12h8"/></svg>
                        <p>No payments found.</p>
                        {% if search_query or mode_filter %}
                            <p><a href="{% url 'payment_history' %}">Clear filters</a></p>
                        {% endif %}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    {% if payments.has_other_pages %}
    <div class="pagination">
        {% if payments.has_previous %}
            <a href="?page=1{% if search_query %}&search={{ search_query }}{% endif %}{% if mode_filter %}&mode={{ mode_filter }}{% endif %}" class="page-link">&laquo; First</a>
            <a href="?page={{ payments.previous_page_number }}{% if search_query %}&search={{ search_query }}{% endif %}{% if mode_filter %}&mode={{ mode_filter }}{% endif %}" class="page-link">Previous</a>
        {% endif %}
        <span class="current-page">Page {{ payments.number }} of {{ payments.paginator.num_pages }}</span>
        {% if payments.has_next %}
            <a href="?page={{ payments.next_page_number }}{% if search_query %}&search={{ search_query }}{% endif %}{% if mode_filter %}&mode={{ mode_filter }}{% endif %}" class="page-link">Next</a>
            <a href="?page={{ payments.paginator.num_pages }}{% if search_query %}&search={{ search_query }}{% endif %}{% if mode_filter %}&mode={{ mode_filter }}{% endif %}" class="page-link">Last &raquo;</a>
        {% endif %}
    </div>
    {% endif %}
</div>

<style>
.page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem; }
.page-title { font-size: 1.8rem; font-weight: 700; background: linear-gradient(135deg, var(--primary), var(--primary-dark)); -webkit-background-clip: text; background-clip: text; color: transparent; }
.page-desc { color: var(--muted); }
.header-stats { display: flex; gap: 1rem; flex-wrap: wrap; }
.stat-badge { display: flex; align-items: center; gap: 0.5rem; padding: 0.5rem 1rem; background: var(--surface-alt); border-radius: 2rem; font-size: 0.85rem; border: 1px solid var(--border); }
.filter-card { background: var(--surface); border-radius: var(--radius); padding: 1.25rem; margin-bottom: 1.5rem; border: 1px solid var(--border); }
.filter-form { display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: flex-end; }
.filter-group { flex: 1; min-width: 180px; }
.filter-input, .filter-select { width: 100%; padding: 0.5rem 0.75rem; border-radius: 0.5rem; border: 1px solid var(--border); background: var(--surface-alt); color: var(--text); }
.filter-actions { display: flex; gap: 0.5rem; }
.btn-filter, .btn-reset { padding: 0.5rem 1rem; border-radius: 2rem; border: none; cursor: pointer; }
.btn-filter { background: var(--primary); color: white; }
.btn-reset { background: var(--surface-alt); color: var(--text); border: 1px solid var(--border); }
.table-card { background: var(--surface); border-radius: var(--radius); border: 1px solid var(--border); overflow: hidden; }
.data-table { width: 100%; border-collapse: collapse; }
.data-table th, .data-table td { padding: 0.75rem 1rem; text-align: left; border-bottom: 1px solid var(--border); }
.data-table th { background: var(--surface-alt); font-weight: 600; font-size: 0.75rem; text-transform: uppercase; color: var(--muted); }
.amount { font-weight: 700; color: var(--primary); }
.btn-sm { background: var(--primary); color: white; padding: 0.2rem 0.6rem; border-radius: 2rem; font-size: 0.7rem; text-decoration: none; }
.empty-row { text-align: center; padding: 2rem; color: var(--muted); }
.pagination { margin-top: 1rem; text-align: center; display: flex; justify-content: center; gap: 0.5rem; flex-wrap: wrap; padding: 1rem; }
.page-link { padding: 0.3rem 0.8rem; background: var(--surface-alt); border: 1px solid var(--border); border-radius: 2rem; text-decoration: none; color: var(--text); }
.page-link:hover { background: var(--primary); color: white; }
.current-page { padding: 0.3rem 0.8rem; background: var(--primary); color: white; border-radius: 2rem; }
</style>
{% endblock %}
